        }
    },
    "scenario_execution_contract": {
        "iid_random": {
            "canonical_recording": "Sort selected flat positions ascending before storing any diagnostic selection record.",
            "eligible_positions": "Flatten native-observed historical positions in C-order from [input_steps, sensor_count].",
            "sampling": "rng.choice(eligible_flat_positions, size=selection_count, replace=False)",
            "selection_count": "floor(conditional_dropout_rate * eligible_position_count + 0.5)"
        },
        "spatial_cluster_outage": {
            "canonical_recording": "Record root_sensor and cluster positions in BFS discovery order.",
            "cluster_growth": "Run FIFO breadth-first search from root_sensor using bfs_neighbour_order in the sealed kNN-4 topology bundle. The cluster is the first K discovered graph-position sensors.",
            "cluster_size": "Use scenario cluster_size_sensors exactly.",
            "intervention": "For each selected cluster sensor, remove only native-observed positions across all 12 historical input steps. Native-missing cells remain native missing and are not counted as artificial removals.",
            "root_sampling": "root_sensor = int(rng.integers(0, sensor_count))"
        },
        "temporal_tail_outage": {
            "canonical_recording": "Sort selected sensor positions ascending before storing any diagnostic selection record.",
            "eligible_sensors": "A sensor is eligible only when all L intended tail positions are native observed.",
            "intervention": "Remove all L tail positions for every selected sensor. When full-tail eligibility is zero, selection_count is zero and the native historical context remains unchanged.",
            "sampling": "rng.choice(full_tail_eligible_sensors, size=selection_count, replace=False)",
            "selection_count": "floor(affected_sensor_fraction * full_tail_eligible_sensor_count + 0.5)"
        }
    },
    "scope": {
        "applies_to_non_clean_scenarios": [
