    "per_window_entropy_derivation": {
        "canonical_primary_window_identity": "split_name plus primary_target_start. Primary-window ordinal is not part of the entropy preimage.",
        "digest_algorithm": "SHA-256",
        "digest_byte_order_for_entropy_words": "big_endian",
        "digest_length_bytes": 32,
