                "protocol_v2_sha256",
                "scenario_id",
                "split_name",
                "split_scenario_seed"
            ],
            "keys_sorted": true,
            "separators": [
                ",",
                ":"
            ]
        },
        "rationale": "Independent entropy per primary target start makes the realization invariant to processing order and prevents zero-eligibility or skipped windows from changing downstream random draws.",
        "rng_initialisation": {
            "bit_generator": "np.random.PCG64",
            "generator": "np.random.Generator(np.random.PCG64(seed_sequence))",
            "seed_sequence": "np.random.SeedSequence(entropy=entropy_words_big_endian_uint32)"
        },
